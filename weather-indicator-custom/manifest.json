{
  "id": "weather-indicator-custom",
  "name": "Weather Indicator (Custom)",
  "version": "1.0.0",
  "minNoctaliaVersion": "4.6.8",
  "author": "Sovereign",
  "license": "MIT",
  "repository": "https://github.com/AfroJoe759/my-noctalia-plugins",
  "description": "Shows the current weather condition and temperature.",
  "tags": [
    "Bar"
  ],
  "entryPoints": {
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "controlCenterWidget": "ControlCenterWidget.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "showTempValue": true,
      "showTempUnit": true,
      "showConditionIcon": true,
      "temperatureMode": "both",
      "tooltipOption": "everything",
      "customColor": "none"
    }
  }
}
